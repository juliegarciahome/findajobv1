// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String?
  googleApiKey String?
  claudeApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile     Profile?
  baseResume  BaseResume?
  jobListings JobListing[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  fullName          String?
  location          String?
  targetRoles       String[] @default([])
  narrativeHeadline String?
  compTarget        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BaseResume {
  id          String   @id @default(cuid())
  userId      String   @unique
  rawMarkdown String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobListing {
  id         String   @id @default(cuid())
  userId     String
  url        String
  company    String?
  role       String?
  rawJd      String?
  source     String?
  status     String   @default("NEW")
  appStatus  String   @default("NONE")
  matchScore Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation Evaluation?

  @@unique([userId, url])
  @@index([userId, status])
}

model Evaluation {
  id                  String   @id @default(cuid())
  jobId               String   @unique
  blockASummary       String?
  blockBMatch         String?
  blockCStrategy      String?
  blockDComp          String?
  blockFInterviewPrep String?
  generatedPdfPath    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  job JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
