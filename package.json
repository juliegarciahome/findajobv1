    "scripts":  {
                    "dev:db":  "npx prisma dev start career_portal -d",
                    "build":  "next build",
                    "start":  "next start",
                    "dev:worker":  "tsx src/lib/workers/ingest-worker.ts",
                    "lint":  "eslint",
