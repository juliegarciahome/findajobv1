# Local Next.js (copy to .env and adjust)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/career_portal"
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# Optional AI keys (ingest / evaluation)
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=

# Ingest queue: omit or "false" for Docker (scraping runs in the web server process).
# Set "true" only when running a separate worker: `npm run dev:worker` (BullMQ consumer).
USE_BULLMQ_INGEST=

# Cloudflare Tunnel (only for docker compose --profile tunnel)
# Create in Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → Token.
# In the same tunnel, set Public Hostname for findmejob.ai → http://web:3005 (Docker network).
CLOUDFLARE_TUNNEL_TOKEN=
